# ── Runtime ───────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Leave blank to use IAM role / instance profile in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_DOCUMENT_BUCKET=demo-tenant-docs

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── OCR ───────────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract
TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# ── allofactorv3 claims DB ────────────────────────────────────
ALLOFACTOR_DB_HOST=localhost
ALLOFACTOR_DB_PORT=3306
ALLOFACTOR_DB_NAME=allofactorv3
ALLOFACTOR_DB_USER=root
ALLOFACTOR_DB_PASSWORD=secret
ALLOFACTOR_DB_POOL_SIZE=5
ALLOFACTOR_DB_MAX_OVERFLOW=10

# ── rcm_workflow DB ───────────────────────────────────────────
WORKFLOW_DB_HOST=localhost
WORKFLOW_DB_PORT=3306
WORKFLOW_DB_NAME=rcm_workflow
WORKFLOW_DB_USER=root
WORKFLOW_DB_PASSWORD=secret
WORKFLOW_DB_POOL_SIZE=5
WORKFLOW_DB_MAX_OVERFLOW=10

# ── Service URLs ──────────────────────────────────────────────
TOOLS_BASE_URL=http://localhost:8001
ORCHESTRATION_BASE_URL=http://localhost:8002
PROFILE_ENGINE_BASE_URL=http://localhost:8010
PROFILE_ENGINE_API_KEY=dev-key

# ── Internal auth (shared secret between services) ────────────
INTERNAL_API_SECRET=changeme-in-production

# ── Availity clearinghouse ────────────────────────────────────
AVAILITY_BASE_URL=https://api.availity.com/availity/v1
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=

# ── Scheduler ─────────────────────────────────────────────────
SCHEDULER_POLL_SECONDS=60
SCHEDULER_BATCH_SIZE=100

# ── Workflow business rules ───────────────────────────────────
ELIGIBILITY_FRESHNESS_DAYS=30
SELF_REG_MAX_ATTEMPTS=3
SELF_REG_FIRST_ATTEMPT_WAIT_HOURS=24
SELF_REG_SECOND_ATTEMPT_WAIT_HOURS=48
SELF_REG_THIRD_ATTEMPT_WAIT_DAYS=7
FACESHEET_MAX_ATTEMPTS=3
FACESHEET_FIRST_ATTEMPT_WAIT_HOURS=24
FACESHEET_SECOND_ATTEMPT_WAIT_HOURS=48
FACESHEET_THIRD_ATTEMPT_WAIT_DAYS=7
